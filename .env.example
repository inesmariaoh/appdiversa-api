# =============================================================================
# AppDiversa API - Plantilla de variables de entorno
# Copiar como .env y completar los valores. No versionar el archivo .env.
# Para Docker Compose, usar tambien .env.docker.example como referencia.
# =============================================================================

# -----------------------------------------------------------------------------
# Django - Configuracion general
# -----------------------------------------------------------------------------
SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=appdiversa_core.settings.local

# -----------------------------------------------------------------------------
# Base de datos MySQL (local, Docker o servicio externo en Render)
# -----------------------------------------------------------------------------
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=3306

# -----------------------------------------------------------------------------
# CORS y frontend
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# Origenes confiables CSRF (opcional; por defecto usa CORS + FRONTEND_URL)
# CSRF_TRUSTED_ORIGINS=https://tu-frontend.onrender.com

# -----------------------------------------------------------------------------
# API interna temporal (sera reemplazada por Keycloak)
# -----------------------------------------------------------------------------
API_INTERNA_TOKEN=

# -----------------------------------------------------------------------------
# Correo electronico y notificaciones
# -----------------------------------------------------------------------------
NOTIFICACIONES_PROVEEDOR=dummy
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.office365.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_DEFAULT_FROM=noreply@example.com
# EMAIL_TIMEOUT=20

# =============================================================================
# Desarrollo local (ejemplo)
# =============================================================================
# DEBUG=True
# DJANGO_SETTINGS_MODULE=appdiversa_core.settings.local
# SECRET_KEY=clave-local-solo-desarrollo
# DB_NAME=appdiversa
# DB_USER=appdiversa_user
# DB_PASSWORD=appdiversa_pass
# DB_HOST=localhost
# DB_PORT=3307

# =============================================================================
# Render / produccion (ejemplo)
# =============================================================================
# DJANGO_SETTINGS_MODULE=appdiversa_core.settings.prod
# DEBUG=False
# SECRET_KEY=generar-clave-secreta-segura-y-unica
# ALLOWED_HOSTS=tu-api.onrender.com,tu-dominio.com
# DB_NAME=appdiversa_prod
# DB_USER=usuario_mysql
# DB_PASSWORD=password_seguro
# DB_HOST=host.mysql.externo
# DB_PORT=3306
# CORS_ALLOWED_ORIGINS=https://tu-frontend.onrender.com,https://tu-dominio.com
# FRONTEND_URL=https://tu-frontend.onrender.com
# NOTIFICACIONES_PROVEEDOR=smtp
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
