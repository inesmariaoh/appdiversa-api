# =============================================================================
# AppDiversa API - Variables de entorno para Docker Compose
# Copiar este archivo como .env antes de ejecutar docker compose up.
# =============================================================================

# -----------------------------------------------------------------------------
# Django - Configuracion general
# -----------------------------------------------------------------------------
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=appdiversa_core.settings.local

# -----------------------------------------------------------------------------
# Base de datos MySQL (servicio db del docker-compose)
# -----------------------------------------------------------------------------
DB_NAME=appdiversa
DB_USER=appdiversa_user
DB_PASSWORD=appdiversa_pass
DB_HOST=db
DB_PORT=3306

# -----------------------------------------------------------------------------
# CORS - Origenes permitidos para el frontend
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Origenes confiables CSRF (opcional; por defecto usa CORS + FRONTEND_URL)
# CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# API interna temporal (sera reemplazada por Keycloak)
# -----------------------------------------------------------------------------
API_INTERNA_TOKEN=change-me-internal-token

# -----------------------------------------------------------------------------
# Correo electronico y notificaciones
# -----------------------------------------------------------------------------
# Desarrollo sin SMTP real:
# NOTIFICACIONES_PROVEEDOR=dummy
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
# Envio real (Office 365 / buzon institucional DANE):
NOTIFICACIONES_PROVEEDOR=smtp
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@dane.gov.co
EMAIL_HOST_PASSWORD=
EMAIL_DEFAULT_FROM=noreply@dane.gov.co
EMAIL_TIMEOUT=20
FRONTEND_URL=http://localhost:3000
